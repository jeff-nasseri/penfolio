# PenFolio environment configuration
# Copy this file to ".env" and adjust values as needed:  cp .env.template .env

# --- Server ---
# Port the API/server listens on (also serves the built Angular UI in production).
PORT=3000
NODE_ENV=production

# --- Database ---
# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=./data/penfolio.sqlite

# --- Auth ---
# Secret used to sign JWT session tokens. CHANGE THIS to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
# Session lifetime for issued tokens.
JWT_EXPIRES_IN=7d

# Default bootstrap credentials (only used the first time the DB is created).
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123
